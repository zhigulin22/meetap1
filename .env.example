# Runtime
APP_ENV=local

# Public
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# Server
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_SECRET
TELEGRAM_MODERATION_CHAT_ID=
TELEGRAM_MODERATION_MOCK=true

# Yandex Tickets import
YANDEX_TICKETS_AUTH=
YANDEX_TICKETS_BASE_URL=https://api.tickets.yandex.net
YANDEX_TICKETS_TIMEOUT_MS=5500

# Cron protection (optional if using Vercel x-vercel-cron header)
CRON_SECRET=

# Face detector tuning
FACE_DETECT_MODEL=gpt-4o-mini
FACE_DETECT_MIN_CONFIDENCE=0.35

# Admin one-shot seed in production (optional)
SEED_MINIMAL_ENABLED=false

# QA bots / staging demo auth
QA_BOTS_CONTROL_TOKEN=CHANGE_ME_QA_CONTROL_TOKEN
QA_BOTS_PASSWORD=QaBots!2026
DEMO_AUTH_ENABLED=false
